{
    "name": "@dichovsky/testrail-api-client",
    "version": "4.0.0",
    "description": "TypeScript API client for TestRail",
    "keywords": [
        "testrail",
        "api",
        "client",
        "typescript",
        "testing"
    ],
    "homepage": "https://github.com/dichovsky/testrail-api-client#readme",
    "bugs": {
        "url": "https://github.com/dichovsky/testrail-api-client/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dichovsky/testrail-api-client.git"
    },
    "license": "MIT",
    "author": "Igor Magdich",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./cli": {
            "import": "./dist/cli.js",
            "default": "./dist/cli.js"
        }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "testrail": "./dist/cli.js"
    },
    "files": [
        "dist",
        "src",
        "skill",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "rm -rf dist && tsc -p tsconfig.prod.json",
        "clean:maps": "find dist -name '*.map' -delete",
        "codemap": "node scripts/generate-codemap.js",
        "codemap:check": "node scripts/generate-codemap.js --check",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "mapping": "node scripts/generate-mapping.js",
        "mapping:check": "node scripts/generate-mapping.js --check",
        "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run skill && npm run skill:check && npm run clean:maps",
        "pretest": "npm run typecheck && npm run lint && npm run format:check && npm run codemap:check && npm run mapping:check",
        "skill": "npm run build && node scripts/generate-skill.js",
        "skill:check": "git diff --exit-code skill/SKILL.md",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:fast": "vitest run --reporter=dot --no-coverage",
        "test:watch": "vitest",
        "typecheck": "tsc"
    },
    "dependencies": {
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.8.0",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.59.3",
        "@vitest/coverage-v8": "^4.1.6",
        "eslint": "^10.4.0",
        "prettier": "~3.8.3",
        "typescript": "~6.0.3",
        "vitest": "^4.1.6"
    },
    "engines": {
        "node": "^20.19.0 || ^22.13.0 || >=24"
    },
    "publishConfig": {
        "access": "public"
    }
}
