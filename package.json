{
  "name": "@dichovsky/testrail-api-client",
  "version": "1.1.0",
  "description": "TypeScript API client for TestRail",
  "keywords": [
    "testrail",
    "api",
    "client",
    "typescript",
    "testing"
  ],
  "homepage": "https://github.com/dichovsky/testrail-api-client#readme",
  "bugs": {
    "url": "https://github.com/dichovsky/testrail-api-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dichovsky/testrail-api-client.git"
  },
  "license": "MIT",
  "author": "Igor Magdich",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "lint": "eslint src tests",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
