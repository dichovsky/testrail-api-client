{
  "name": "@dichovsky/testrail-api-client",
  "version": "1.1.0",
  "description": "TypeScript API client for TestRail",
  "keywords": [
    "testrail",
    "api",
    "client",
    "typescript",
    "testing"
  ],
  "homepage": "https://github.com/dichovsky/testrail-api-client#readme",
  "bugs": {
    "url": "https://github.com/dichovsky/testrail-api-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dichovsky/testrail-api-client.git"
  },
  "license": "MIT",
  "author": "Igor Magdich",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "lint": "eslint src tests",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
