{
    "name": "@dichovsky/testrail-api-client",
    "version": "1.1.0",
    "description": "TypeScript API client for TestRail",
    "keywords": [
        "testrail",
        "api",
        "client",
        "typescript",
        "testing"
    ],
    "homepage": "https://github.com/dichovsky/testrail-api-client#readme",
    "bugs": {
        "url": "https://github.com/dichovsky/testrail-api-client/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dichovsky/testrail-api-client.git"
    },
    "license": "MIT",
    "author": "Igor Magdich",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "src",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "rm -rf dist && tsc",
        "codemap": "node scripts/generate-codemap.js",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "prepublishOnly": "npm run build",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:fast": "vitest run --reporter=dot --no-coverage",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitest/coverage-v8": "^4.1.4",
        "eslint": "^10.2.0",
        "prettier": "~3.8.2",
        "typescript": "~6.0.2",
        "vitest": "^4.1.4"
    },
    "engines": {
        "node": "^20.19.0 || ^22.13.0 || >=24"
    }
}
